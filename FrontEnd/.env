# Frontend Environment Configuration

# ==========================================
# API Configuration
# ==========================================
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=10000

# ==========================================
# App Configuration
# ==========================================
