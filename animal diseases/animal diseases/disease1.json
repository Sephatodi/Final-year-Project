  "design_documents": {
    "_id": "_design/livestock_diseases",
    "views": {
      "by_disease_type": {
        "map": "function(doc) {\n  if (doc.type === 'viral' || doc.type === 'bacterial') {\n    emit(doc.type, doc.name);\n  }\n}"
      },
      "by_host": {
        "map": "function(doc) {\n  if (doc.hosts) {\n    for (var i in doc.hosts) {\n      emit(doc.hosts[i], doc.name);\n    }\n  }\n}"
      },
      "by_zoonotic_status": {
        "map": "function(doc) {\n  if (doc.zoonotic !== undefined) {\n    emit(doc.zoonotic, { name: doc.name, zoonotic: doc.zoonotic });\n  }\n}"
      },
      "by_notifiable_status": {
        "map": "function(doc) {\n  if (doc.notifiable === true) {\n    emit(doc.name, doc.type);\n  }\n}"
      },
      "by_virulence": {
        "map": "function(doc) {\n  if (doc.virulence) {\n    emit(doc.virulence, doc.name);\n  }\n}"
      }
    }
  },
  "query_examples": {
    "get_all_viral_diseases": {
