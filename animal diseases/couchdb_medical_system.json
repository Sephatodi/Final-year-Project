    "load_documents": "For each document in each database, use: curl -X POST http://admin:password123@127.0.0.1:5984/{database_name} -H 'Content-Type: application/json' -d @document.json",
    "load_design_documents": "For each design document, use: curl -X PUT http://admin:password123@127.0.0.1:5984/{database_name}/{design_doc_id} -H 'Content-Type: application/json' -d @design_doc.json"
  },
