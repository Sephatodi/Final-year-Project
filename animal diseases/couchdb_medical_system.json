    "knowledge_base": {
      "documents": [
        {
          "_id": "kb_article_001",
          "type": "knowledge_article",
          "title": "Understanding Diabetes Management",
          "category": "Patient Education",
          "subcategory": "Chronic Disease Management",
          "tags": ["diabetes", "insulin", "blood_sugar", "nutrition"],
          "author": "Dr. Sarah Johnson",
          "publish_date": "2026-01-15T00:00:00Z",
          "last_reviewed": "2026-01-15T00:00:00Z",
          "version": 3,
          "content": {
            "summary": "Comprehensive guide to managing type 2 diabetes",
            "sections": [
              {
                "heading": "Understanding Blood Sugar",
                "body": "Blood sugar levels indicate how well your body processes glucose. Normal fasting blood sugar is between 70-99 mg/dL."
              },
              {
                "heading": "Medication Adherence",
                "body": "Taking medications as prescribed is crucial for diabetes management. Metformin is typically the first-line medication."
              },
              {
                "heading": "Lifestyle Modifications",
                "body": "Regular exercise, healthy diet, and weight management can significantly improve blood sugar control."
              }
            ]
          },
          "related_diseases": ["disease_001"],
          "references": [
            "American Diabetes Association 2025",
            "WHO Diabetes Guidelines"
          ],
          "attachments": {
            "infographic": "diabetes_management.pdf",
            "video_tutorial": "insulin_injection.mp4"
          },
          "view_count": 1542,
          "rating": 4.8,
          "status": "published"
        },
        {
          "_id": "kb_guideline_001",
          "type": "clinical_guideline",
          "title": "Hypertension Treatment Protocol 2026",
          "specialty": "Cardiology",
          "evidence_level": "Grade A",
          "recommendations": [
            {
              "condition": "Stage 1 Hypertension",
              "action": "Lifestyle modifications for 3-6 months",
              "medication": "Thiazide diuretic"
            },
            {
              "condition": "Stage 2 Hypertension",
              "action": "Immediate medication",
              "medication": "ACE inhibitor + Calcium channel blocker"
            }
          ],
          "contraindications": [
            "ACE inhibitors in pregnancy",
            "Beta-blockers in asthma"
          ],
          "approval_date": "2026-01-01T00:00:00Z",
          "expiry_date": "2028-01-01T00:00:00Z",
          "status": "active"
        }
      ],
      "design_documents": [
        {
          "_id": "_design/knowledge_base",
          "views": {
            "by_category": {
              "map": "function(doc) {\n  if (doc.type === 'knowledge_article' || doc.type === 'clinical_guideline') {\n    emit(doc.category, { title: doc.title, type: doc.type });\n  }\n}"
            },
            "by_tag": {
              "map": "function(doc) {\n  if (doc.type === 'knowledge_article' && doc.tags) {\n    for (var i in doc.tags) {\n      emit(doc.tags[i], doc.title);\n    }\n  }\n}"
            },
            "recent_first": {
              "map": "function(doc) {\n  if (doc.type === 'knowledge_article') {\n    emit(doc.publish_date, doc.title);\n  }\n}"
            }
          }
        }
      ]
