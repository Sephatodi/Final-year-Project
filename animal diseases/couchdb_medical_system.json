      "design_documents": [
        {
          "_id": "_design/message_queue",
          "views": {
            "pending_messages": {
              "map": "function(doc) {\n  if (doc.type === 'queued_message' && doc.status === 'pending') {\n    emit([doc.priority, doc.metadata.created_at], null);\n  }\n}"
            },
            "by_recipient": {
              "map": "function(doc) {\n  if (doc.type === 'queued_message') {\n    emit(doc.message.to, { status: doc.status, priority: doc.priority });\n  }\n}"
            },
            "by_status": {
              "map": "function(doc) {\n  if (doc.type === 'queued_message') {\n    emit(doc.status, { id: doc._id, created_at: doc.metadata.created_at });\n  }\n}"
            },
            "dead_letters": {
              "map": "function(doc) {\n  if (doc.type === 'dead_letter' && doc.resolved === false) {\n    emit(doc.failure_timestamp, doc.failure_reason);\n  }\n}"
            },
            "stuck_messages": {
              "map": "function(doc) {\n  if (doc.type === 'queued_message' && \n      doc.status === 'processing' && \n      doc.processing.locked_until && \n      doc.processing.locked_until < new Date().toISOString()) {\n    emit(doc.processing.locked_until, doc._id);\n  }\n}"
            }
          }
        }
      ]
    }
